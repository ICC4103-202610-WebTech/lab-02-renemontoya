<div class="container py-5">
  <header class="text-center mb-5">
    <div class="profile-container mb-3">
      <%# Esta es la etiqueta mágica de Rails para tu foto %>
      <%= image_tag "profile.jpg", alt: "Photo of René Montoya", class: "profile-image rounded-circle shadow", style: "width: 180px; height: 180px; object-fit: cover; border: 5px solid #0d6efd;" %>
    </div>
    <h1 class="display-4 fw-bold">René Javier Montoya Tapia</h1>
    <p class="lead text-muted">Lab 2 Web Technologies</p>
    <hr class="my-4" style="width: 100px; margin: auto; border-top: 3px solid #0d6efd;">
  </header>

  <div class="row justify-content-center">
    <div class="col-md-10">
      
      <section class="card shadow-sm p-4 mb-4 border-0 bg-light">
        <h2 class="text-primary mb-3"><i class="bi bi-person-fill"></i> About Me</h2>
        <div class="row">
          <div class="col-sm-4"><strong>Name:</strong></div>
          <div class="col-sm-8">René Javier Montoya Tapia</div>
        </div>
        <div class="row mt-2">
          <div class="col-sm-4"><strong>Major:</strong></div>
          <div class="col-sm-8">Civil Electrical Engineering</div>
        </div>
        <div class="row mt-2">
          <div class="col-sm-4"><strong>University Enrollment:</strong></div>
          <div class="col-sm-8">2020</div>
        </div>
        <div class="row mt-2">
          <div class="col-sm-4"><strong>GitHub:</strong></div>
          <div class="col-sm-8">
            <a href="https://github.com/renemontoya" target="_blank" class="text-decoration-none">
              <i class="bi bi-github"></i> github.com/renemontoya
            </a>
          </div>
        </div>
        <div class="mt-3">
          <strong>Personal Summary:</strong>
          <p class="mt-2 text-secondary">
            I am a Civil Electrical Engineering student interested in automation, energy, robotics,
            programming, and technology innovation. I enjoy building engineering projects and learning
            new tools that help me solve real-world problems. In my free time, I enjoy listening to music, 
            working on electronics projects, and boxing.
          </p>
        </div>
      </section>

      <section class="card shadow-sm p-4 mb-4 border-0">
        <h2 class="text-primary mb-3"><i class="bi bi-star-fill"></i> Skills</h2>
        <div class="table-responsive">
          <table class="table table-hover border">
            <thead class="table-dark">
              <tr>
                <th>Skill</th>
                <th>Level</th>
              </tr>
            </thead>
            <tbody>
              <tr><td>Python</td><td><span class="badge bg-success">Advanced</span></td></tr>
              <tr><td>JavaScript</td><td><span class="badge bg-info text-dark">Basic</span></td></tr>
              <tr><td>HTML/CSS</td><td><span class="badge bg-info text-dark">Basic</span></td></tr>
              <tr><td>Git</td><td><span class="badge bg-primary">Intermediate</span></td></tr>
              <tr><td>Excel</td><td><span class="badge bg-success">Advanced</span></td></tr>
              <tr><td>SQL</td><td><span class="badge bg-primary">Intermediate</span></td></tr>
              <tr><td>Ruby</td><td><span class="badge bg-info text-dark">Basic</span></td></tr>
              <tr><td>DigSilent</td><td><span class="badge bg-success">Advanced</span></td></tr>
              <tr><td>Latex</td><td><span class="badge bg-success">Advanced</span></td></tr>
              <tr><td>Matlab</td><td><span class="badge bg-success">Advanced</span></td></tr>
              <tr><td>English</td><td><span class="badge bg-success">Advanced</span></td></tr>
              <tr><td>Spanish</td><td><span class="badge bg-secondary">Native</span></td></tr>
            </tbody>
          </table>
        </div>
      </section>

      <section class="card shadow-sm p-4 mb-5 border-0 bg-dark text-white text-center">
        <h2 class="mb-3 text-info">Interactive Section</h2>
        <p>Write a short message and press the button to update the text below:</p>

        <div class="input-group mb-3 max-width-500 mx-auto" style="max-width: 500px;">
          <input type="text" id="userInput" class="form-control" placeholder="Type something here...">
          <button class="btn btn-info" onclick="changeMessage()">Update Message</button>
        </div>

        <p id="dynamicText" class="fs-5 mt-3 text-info fw-italic text-break">
          This text will change when you use the input and button.
        </p>
      </section>

    </div>
  </div>
</div>

<%# JavaScript incluido directamente para que funcione de inmediato %>
<script>
  function changeMessage() {
    const input = document.getElementById("userInput").value;
    const dynamicText = document.getElementById("dynamicText");

    if (input.trim() !== "") {
      dynamicText.textContent = `"${input}"`;
    } else {
      dynamicText.textContent = "Please enter some text first.";
    }
  }
</script>